    ).join('');

    // Projects
    const projects = [
      { title:'Project Alpha', desc:'A real-time dashboard built with React and WebSockets for live analytics.', tags:['React','Node.js'], emoji:'📊' },
      { title:'DevTools CLI', desc:'An open-source command-line tool to automate dev workflows.', tags:['Python','CLI'], emoji:'⚡' },
      { title:'Portfolio Engine', desc:'A static site generator for creating beautiful developer portfolios.', tags:['Next.js','Tailwind'], emoji:'🎨' },
      { title:'API Gateway', desc:'Scalable microservice gateway handling 1M+ requests daily.', tags:['Go','Docker'], emoji:'🔌' },
      { title:'TaskFlow', desc:'A collaborative task manager with drag-and-drop and offline support.', tags:['Vue','PWA'], emoji:'✅' },
      { title:'ML Playground', desc:'Interactive web app to visualize machine learning models in the browser.', tags:['Python','TensorFlow'], emoji:'🤖' },
    ];
    document.getElementById('projects-grid').innerHTML = projects.map(p => `
      <article class="card-hover bg-white/5 border border-white/10 rounded-2xl p-6 fade-up">
        <div class="text-4xl mb-4">${p.emoji}</div>
        <h3 class="text-xl font-semibold mb-2 text-white">${p.title}</h3>
        <p class="text-slate-400 text-sm mb-4 leading-relaxed">${p.desc}</p>
        <div class="flex flex-wrap gap-2 mb-5">
          ${p.tags.map(t=>`<span class="text-xs px-2.5 py-1 rounded-md bg-indigo-500/10 text-indigo-300 border border-indigo-500/20">${t}</span>`).join('')}
        </div>
        <div class="flex gap-4 text-sm font-medium">
          <a href="#" class="text-indigo-400 hover:text-indigo-300 transition">Live Demo →</a>
          <a href="#" class="text-slate-400 hover:text-white transition">Code</a>
        </div>
      </article>
    `).join('');

    document.getElementById('year').textContent = new Date().getFullYear();

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
